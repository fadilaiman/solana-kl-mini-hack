# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=solemandate_db
POSTGRES_USER=solemandate_user
POSTGRES_PASSWORD=REPLACE_ME
# host 'db' = the postgres service name on solemandate-net
DATABASE_URL=postgresql://solemandate_user:REPLACE_ME@db:5432/solemandate_db?schema=public

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=https://solemandate.saasku.my

# ─── Solana ──────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# NEXT_PUBLIC_* are exposed to the browser (checkout needs them)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# System fee-payer / delegate keypair.
# SECRET is a base58-encoded 64-byte secret key — NEVER commit the real value.
SYSTEM_FEEPAYER_SECRET=REPLACE_ME_BASE58_SECRET
# Public key of the above (also exposed to the browser to build the approve ix)
NEXT_PUBLIC_SYSTEM_FEEPAYER_PUBKEY=REPLACE_ME_BASE58_PUBKEY

# ─── Debit engine ────────────────────────────────────────────
# testing => 10-minute cycles; production => monthly cycles
DEBIT_ENVIRONMENT=testing
# true => skip real RPC sends, write mock signatures (demo fallback)
MOCK_CHAIN=false
# shared secret guarding the cron sweep endpoint
CRON_SECRET=REPLACE_ME
