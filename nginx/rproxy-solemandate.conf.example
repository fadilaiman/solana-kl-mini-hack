# ─────────────────────────────────────────────────────────────
# REFERENCE ONLY — apply this on the rproxy reverse proxy host
# (REDACTED), NOT inside this project's containers.
#
#   scp this to:  /etc/nginx/conf.d/solemandate.conf   on rproxy
#   then:         sudo nginx -t && sudo systemctl reload nginx
#
# DNS: solemandate.saasku.my  ->  A  REDACTED
# Cert: sudo certbot --nginx -d solemandate.saasku.my
# ─────────────────────────────────────────────────────────────

upstream solemandate_backend {
    server REDACTED:14022;   # solemandate-nginx container on the app server
}

server {
    listen 80;
    server_name solemandate.saasku.my;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name solemandate.saasku.my;

    ssl_certificate     /etc/letsencrypt/live/solemandate.saasku.my/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/solemandate.saasku.my/privkey.pem;

    access_log /var/log/nginx/solemandate-access.log;
    error_log  /var/log/nginx/solemandate-error.log;

    location / {
        proxy_pass         http://solemandate_backend;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        proxy_connect_timeout 60s;
        proxy_read_timeout 60s;
    }
}
